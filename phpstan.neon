parameters:
    level: 10
    paths:
        - src
        - tests
    ignoreErrors:
        # PHPMD @SuppressWarnings annotations — PHPStan cannot parse PHPMD syntax.
        # These tags are intentional and correct for PHPMD; they are not PHPStan directives.
        - identifier: phpDoc.parseError

        # Ignore dummy class strings in tests
        - identifier: argument.type
          message: '~expects class-string(.*), string given~'
          paths:
            - tests/

        # Test helper entities/inlined classes use write-only properties that are
        # exercised via getters, reflection, or the Doctrine ORM internals.
        - identifier: property.onlyWritten
          paths:
            - tests/
